# Anthropic API key — billing for pairing proposals and specimen generation.
# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Google Fonts Developer API key (free, 10k requests/day) — used to fetch the
# font catalog. Enable the "Web Fonts Developer API" in a Google Cloud project,
# then create an API key: https://console.cloud.google.com/apis/credentials
GOOGLE_FONTS_API_KEY=AIza...

# Optional model overrides.
# ANTHROPIC_MODEL=claude-opus-4-8          # specimen generation (agent job)
# ANTHROPIC_PROPOSAL_MODEL=claude-sonnet-4-6   # pairing proposals
